{
  "enabled": true,
  "name": "Sync React Tests on Save",
  "description": "When a React component file (.tsx) in frontend/src/components/ or frontend/src/app/ is saved, update or create the matching test file to cover the component's current props, rendering, and interactions.",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "frontend/src/components/*.tsx",
      "frontend/src/app/**/*.tsx"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "A React component file was just saved. Read the saved component and its existing test file (if any). Then update or create the matching test file so it covers the component's current props, rendering, and key interactions. Place test files alongside the component with a `.test.tsx` suffix. Use the project's existing test patterns and libraries (check package.json for the test runner). Do not modify the component itself."
  }
}