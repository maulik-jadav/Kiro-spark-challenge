{
  "enabled": true,
  "name": "Run Pytest on Backend Save",
  "description": "When any Python file in backend/agents/ or backend/core/ is saved, automatically run the backend test suite with pytest.",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "backend/agents/*.py",
      "backend/core/*.py"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "cd backend && python -m pytest tests/ -v --tb=short"
  }
}